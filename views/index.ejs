<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cakes N' Crumb Bakery</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="main.css">
    <link rel="stylesheet" href="order.css">
</head>
<body>
    <!-- Header -->
     <%- include("_header.ejs") %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h1>Artisan Baked Goods Made With Love</h1>
                <p>Discover the perfect blend of traditional recipes and modern flavors in every bite</p>
                <a href="#featured-products" class="cta-button">Explore Our Products</a>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="featured-products" id="featured-products">
        <div class="container">
            <h2 class="section-title">Our Signature Creations</h2>
            <p class="section-subtitle">Handcrafted with the finest ingredients for exceptional flavor</p>
            
            <div class="products-grid">
                <% if (products && products.length > 0) { %>

                    <% products.forEach(product => { %>
                    <div class="product-card">
                        
                        <div class="product-img"
                            style="background-image: url('<%= product.image_url ? product.image_url : "/images/default.jpg" %>');">
                        </div>

                        <div class="product-info">
                        <h3 class="product-title"><%= product.name %></h3>
                        <p class="product-desc"><%= product.description %></p>
                        <p class="product-price">Ksh <%= product.price %></p>

                        <a href="/products/<%= product.id %>" class="cta-button">
                            View Product
                        </a>
                        </div>

                    </div>
                    <% }) %>

                <% } else { %>
                    <p>No products available yet.</p>
                <% } %>
            </div>

        </div>
    </section>

    <!-- About Section -->
    <section class="about">
        <div class="container">
            <div class="about-content">
                <div class="about-text">
                    <h2 class="section-title">Our Story</h2>
                    <p>My love for baking began in my home kitchen, where experimenting with recipes turned into a deep passion for creating delicious, handcrafted treats. A memorable turning point came last Christmas when my brother and I baked a special cake and cookies for our family — seeing the joy our creations brought made me realize this was more than just a hobby; it was my calling.</p>
                    <p>Instead of enrolling in a baking school, I chose to invest directly in my dream — buying my first oven and turning my kitchen into my classroom. On June 19th, 2025, I launched my baking business while continuing my university studies. Each day, I learn, refine my techniques, and share my baked goods with fellow students and the community, one sweet creation at a time.</p>
                    <p>We source locally whenever possible, supporting our community and reducing our environmental footprint while delivering the freshest products to our customers.</p>
                    <a href="#" class="cta-button">Learn More About Us</a>
                </div>
                <div class="about-image">
                    <img src="/images/owner.jpg" alt="Baker preparing dough">
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials">
        <div class="container">
            <h2 class="section-title">What Our Customers Say</h2>
            <p class="section-subtitle">Don't just take our word for it - hear from our satisfied customers</p>
            
            <div class="testimonial-grid">
                    <div class="testimonial-card">
                    <p class="testimonial-text">The sourdough bread from Sweet Delights is the best I've ever had. It's become a staple in our household - we can't start our day without it!</p>
                    <div class="testimonial-author">
                        <div class="author-img" style="background-image: url('https://randomuser.me/api/portraits/women/65.jpg');"></div>
                        <div>
                            <h4>Sarah Johnson</h4>
                            <p>Regular Customer</p>
                        </div>
                    </div>
                </div>
                
                <div class="testimonial-card">
                    <p class="testimonial-text">I ordered a custom birthday cake for my daughter's party, and it was both beautiful and delicious. The attention to detail was exceptional.</p>
                    <div class="testimonial-author">
                        <div class="author-img" style="background-image: url('https://randomuser.me/api/portraits/men/32.jpg');"></div>
                        <div>
                            <h4>Michael Thompson</h4>
                            <p>Customer</p>
                        </div>
                    </div>
                </div>
                
                <div class="testimonial-card">
                    <p class="testimonial-text">As a coffee shop owner, I've been sourcing pastries from Sweet Delights for over a year. My customers consistently praise the quality and flavor.</p>
                    <div class="testimonial-author">
                        <div class="author-img" style="background-image: url('https://randomuser.me/api/portraits/women/44.jpg');"></div>
                        <div>
                            <h4>Emily Rodriguez</h4>
                            <p>Local Business Owner</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Order Process -->
    <section class="order">
        <div class="container">
            <h2 class="section-title">How To Order</h2>
            <p class="section-subtitle">Getting your favorite baked goods is simple and convenient</p>
            
            <div class="order-steps">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h3>Browse Our Selection</h3>
                    <p>Explore our menu of artisan breads, pastries, cakes, and custom creations</p>
                </div>
                
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h3>Place Your Order</h3>
                    <p>Select items, choose pickup or delivery time, and complete your purchase</p>
                </div>
                
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h3>Enjoy Freshness</h3>
                    <p>Pick up your order or have it delivered - always fresh and delicious</p>
                </div>
            </div>
            
            <a href="/order" class="cta-button">Start Your Order Now</a>
        </div>
    </section>

    <!-- Footer -->
    <%- include("_footer.ejs") %>

    <script src="main.js"></script>
</body>
</html>